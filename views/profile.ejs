<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Socio</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white">
        <div class="w-full flex items-end bg-zinc-900">
            <a href="/logout" class="absolute top-4 right-4 px-3 py-2 bg-red-500 text-white rounded-md hover:bg-red-600">Logout</a>
        </div>

        <h1 class="text-3xl font-medium text-white px-2 py-6 mb-5"><span class="font-bold">Hello</span>, <%= user.name %> 👋</h1>
        <p class="text-lg text-gray-300 px-2">Welcome to your profile!</p>
        <h5 class="px-2 py-4">Create a new post</h5>

        <form action="/post" method="POST">
            <textarea class="w-1/3 resize-none bg-transparent border-2 border-zinc-800 rounded-md p-3 outline-none m-2" name="content" placeholder="What's on your mind?"></textarea>
            <input class="px-6 py-2 w-40 bg-blue-500 text-white text-sm rounded-md hover:bg-blue-600 transition duration-300 mt-3 block m-2" type="submit" value="Create Post">
        </form>

        <div class="posts mt-36 m-2">
            <h3 class="text-zinc-400">Your Posts</h3>

            <div class="postcontainer mt-5">
                <% user.posts.reverse().forEach(function(post) { %>

                <div class="post w-1/3 p-5 border-[1px] rounded-md bg-zinc-800 border-zinc-700 text-white">
                    <h4 class="text-blue-500 mb-2">@<%= user.name %></h4>
                    <p class="text-sm tracking-tight"><%= post.content %></p>
                   
                    <div class="btns flex gap-4 mt-5">
                        <a class="text-blue-500" href="">Like</a>
                        <a class="text-zinc-600" href="">edit</a>
                    </div>

                </div>

                <% }) %>

            </div> 

        </div>

    </div>
</body>
</html>