<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Socio</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white">

            <a href="/logout" class="px-3 py-2 bg-red-500 text-white-sm rounded-md hover:bg-red-600 transition duration-300 inline-block m-2 mt-4 w-20">Logout</a>

            <h1 class="text-3xl font-medium text-white px-2 py-6 mb-5"><span class="font-bold">Hello</span>, <%= user.name %> 👋</h1>
            <p class="text-lg text-gray-300 px-2">Welcome to your profile!</p>
            <h5 class="px-2 py-4">Create a new post</h5>

            <form action="/posts" method="POST">
                <textarea class="w-1/3 resize-none bg-transparent border-2 border-zinc-800 rounded-md p-3 outline-none m-2" placeholder="What's on your mind?"></textarea>
                <input class="px-6 py-2 w-40 bg-blue-500 text-white text-sm rounded-md hover:bg-blue-600 transition duration-300 mt-3 block m-2" type="submit" value="Create Post">
            </form>
        
    </div>
</body>
</html>