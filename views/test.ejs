<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Socio</title>

    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body>

    <div class="w-full min-h-screen bg-zinc-900 text-white p-6">

        <h1 class="text-3xl font-semibold mb-8">Upload File</h1>

        <form action="/upload" method="POST" enctype="multipart/form-data"class="flex items-center gap-4">
            <input class="bg-zinc-800 border border-zinc-700 rounded-md px-3 py-2 text-sm text-zinc-400" type="file" name="image">
            <input class="px-5 py-2 bg-blue-500 rounded-md hover:bg-blue-600 transition duration-300 cursor-pointer" type="submit" value="Upload File">

        </form>

    </div>

</body>
</html>