<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Socio</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900">

        <form action="/create" method="POST" class="w-full h-screen flex flex-col items-center justify-center gap-4">
            <input class="w-1/3 p-2 rounded-md bg-zinc-800 text-white focus:outline-none focus:ring-2 focus:ring-blue-500"type="text" name="name" placeholder="Name" >
            <input class="w-1/3 p-2 rounded-md bg-zinc-800 text-white focus:outline-none focus:ring-2 focus:ring-blue-500" type="text" name="username" placeholder="Username" >
            <input class="w-1/3 p-2 rounded-md bg-zinc-800 text-white focus:outline-none focus:ring-2 focus:ring-blue-500" type="email" name="email" placeholder="Email" >
            <input class="w-1/3 p-2 rounded-md bg-zinc-800 text-white focus:outline-none focus:ring-2 focus:ring-blue-500" type="password" name="password" placeholder="Password" >
            <input class="px-6 py-2 bg-blue-500 text-white rounded-md hover:bg-blue-600 transition duration-300" type="submit" value="Create Account">
        </form>
        
    </div>
</body>
</html>