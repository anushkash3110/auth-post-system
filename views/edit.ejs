<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Socio</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white">
        <div class="w-full flex items-end bg-zinc-900">
            <a href="/logout" class="absolute top-4 right-4 px-3 py-2 bg-red-500 text-white rounded-md hover:bg-red-600">Logout</a>
        </div>


        <h5 class="px-2 py-4">Edit your post</h5>

        <form action="/update/<%= post._id %>" method="POST">
            <textarea class="w-1/3 resize-none bg-transparent border-2 border-zinc-800 rounded-md p-3 outline-none m-2" name="content"><%= post.content %></textarea>
            <input class="px-6 py-2 w-40 bg-blue-500 text-white text-sm rounded-md hover:bg-green-600 transition duration-300 mt-3 block m-2" type="submit" value="Update Changes">
        </form>


    </div>
</body>
</html>